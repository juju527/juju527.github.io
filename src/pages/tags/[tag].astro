---
import PageHeader from "../../components/PageHeader.astro";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getVisiblePosts } from "../../lib/posts";
import { getTagSummaries, type TagSummary } from "../../lib/tags";

export async function getStaticPaths() {
  const posts = await getVisiblePosts({ includeDrafts: false });

  return getTagSummaries(posts).map((tag) => ({
    params: { tag: tag.slug },
    props: { tag },
  }));
}

interface Props {
  tag: TagSummary;
}

const { tag } = Astro.props;
const articleCount = `${tag.count} public ${tag.count === 1 ? "article" : "articles"}`;
const description = `Browse ${articleCount} tagged “${tag.name}”.`;
---

<BaseLayout title={`Tag: ${tag.name}`} description={description}>
  <a class="back-link" href="/tags/">&larr; All tags</a>
  <PageHeader eyebrow={articleCount} title={`Articles tagged “${tag.name}”`} description={description} />

  {
    tag.posts.length > 0 ? (
      <div class="post-list">
        {tag.posts.map((post) => <PostCard post={post} />)}
      </div>
    ) : (
      <p class="empty-state">No public articles use this tag.</p>
    )
  }
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: var(--space-6);
    font-size: var(--font-size-sm);
    font-weight: 700;
  }

  .post-list {
    display: grid;
  }

  .empty-state {
    color: var(--color-text-muted);
  }
</style>
