---
import PageHeader from "../../components/PageHeader.astro";
import { siteConfig } from "../../config/site";
import { profileData } from "../../data/profile";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description={`About ${siteConfig.name}, with an introduction and contact links.`}>
  <PageHeader
    eyebrow="About"
    title={siteConfig.name}
  />

  <div class="about-sections">
    <section aria-labelledby="introduction-title">
      <h2 id="introduction-title">Introduction</h2>
      {profileData.introduction.map((paragraph) => <p>{paragraph}</p>)}
    </section>

    <section aria-labelledby="contact-title">
      <h2 id="contact-title">Contact and social links</h2>
      <ul class="contact-list">
        {
          siteConfig.socialLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label} <span aria-hidden="true">↗</span></a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .about-sections {
    display: grid;
    gap: var(--space-8);
  }

  .about-sections > section {
    scroll-margin-top: var(--space-5);
  }

  .about-sections h2 {
    font-size: var(--font-size-xl);
  }

  .contact-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .contact-list a {
    font-weight: 700;
  }
</style>
