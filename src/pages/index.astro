---
import PostCard from "../components/PostCard.astro";
import { siteConfig } from "../config/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisiblePosts } from "../lib/posts";

const posts = await getVisiblePosts({ includeDrafts: false });
const recentPosts = posts.slice(0, 3);
const featuredPosts = posts.filter(({ data }) => data.featured).slice(0, 2);
const homepageLinks = [
  ...siteConfig.navigation.map((link) => ({ ...link, external: false })),
  ...siteConfig.socialLinks.map((link) => ({ ...link, external: true })),
];
---

<BaseLayout description={siteConfig.description} wide>
  <div class="home">
    <section class="hero" aria-labelledby="hero-title">
      <h1 id="hero-title">{siteConfig.name}</h1>
      <p class="hero__summary">{siteConfig.description}</p>
      <nav aria-label="Homepage shortcuts">
        <ul class="hero__links">
          {
            homepageLinks.map((link, index) => (
              <li>
                <a class:list={{ "hero__link--primary": index === 0 }} href={link.href}>
                  {link.label}
                  {link.external && <span aria-hidden="true">↗</span>}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </section>

    <section class="home-section" aria-labelledby="recent-title">
      <header class="section-heading">
        <div>
          <p>Writing</p>
          <h2 id="recent-title">Recent articles</h2>
        </div>
        <a href="/blog/">View all articles <span aria-hidden="true">→</span></a>
      </header>
      {
        recentPosts.length > 0 ? (
          <div class="post-list">
            {recentPosts.map((post) => <PostCard post={post} headingLevel="h3" />)}
          </div>
        ) : (
          <div class="empty-state">
            <p>No published articles yet.</p>
            <p>New writing will appear here once it is ready.</p>
          </div>
        )
      }
    </section>

    <section class="home-section" aria-labelledby="featured-title">
      <header class="section-heading">
        <div>
          <p>Selected work</p>
          <h2 id="featured-title">Featured</h2>
        </div>
      </header>
      {
        featuredPosts.length > 0 ? (
          <div class="post-list">
            {featuredPosts.map((post) => <PostCard post={post} headingLevel="h3" />)}
          </div>
        ) : (
          <div class="featured-placeholder">
            <p class="featured-placeholder__label">Content placeholder</p>
            <h3>Featured work will appear here</h3>
            <p>
              No articles are marked as featured yet. This space is intentionally kept as a
              placeholder until new work is ready to publish.
            </p>
          </div>
        )
      }
    </section>

  </div>
</BaseLayout>

<style>
  .home {
    display: grid;
    gap: var(--space-9);
  }

  .hero {
    padding-block: clamp(var(--space-5), 6vw, var(--space-9));
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .section-heading > div > p {
    margin-bottom: var(--space-3);
    color: var(--color-accent);
    font-size: var(--font-size-sm);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .hero h1 {
    margin-bottom: var(--space-5);
    font-size: clamp(2.5rem, 8vw, 5.5rem);
    letter-spacing: -0.055em;
    line-height: 1;
  }

  .hero__summary {
    max-width: 46rem;
    margin-bottom: var(--space-6);
    color: var(--color-text-muted);
    font-size: var(--font-size-xl);
    line-height: 1.55;
  }

  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero__links a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 2.75rem;
    padding: var(--space-2) var(--space-4);
    border: var(--border-width) solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    font-weight: 700;
    text-decoration: none;
  }

  .hero__links a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-hover);
    background: var(--color-surface-muted);
  }

  .hero__links .hero__link--primary {
    border-color: var(--color-accent);
    color: var(--color-background);
    background: var(--color-accent);
  }

  .hero__links .hero__link--primary:hover {
    border-color: var(--color-accent-hover);
    color: var(--color-background);
    background: var(--color-accent-hover);
  }

  .home-section {
    width: min(100%, 60rem);
    margin-inline: auto;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-5);
    margin-bottom: var(--space-5);
  }

  .section-heading h2 {
    margin-bottom: 0;
    font-size: var(--font-size-2xl);
    letter-spacing: -0.035em;
  }

  .section-heading > a {
    flex: none;
    font-size: var(--font-size-sm);
    font-weight: 700;
  }

  .post-list {
    display: grid;
  }

  .empty-state,
  .featured-placeholder {
    padding: var(--space-6);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    box-shadow: var(--shadow-sm);
  }

  .empty-state p,
  .featured-placeholder p {
    color: var(--color-text-muted);
  }

  .empty-state p:last-child,
  .featured-placeholder p:last-child {
    margin-bottom: 0;
  }

  .featured-placeholder {
    border-style: dashed;
  }

  .featured-placeholder__label {
    margin-bottom: var(--space-2);
    font-size: var(--font-size-xs);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .featured-placeholder h3 {
    margin-bottom: var(--space-3);
    font-size: var(--font-size-xl);
  }

  @media (max-width: 40rem) {
    .home {
      gap: var(--space-8);
    }

    .hero {
      padding-block: var(--space-5) var(--space-7);
    }

    .hero h1 {
      font-size: clamp(2.5rem, 15vw, 4rem);
    }

    .hero__links {
      gap: var(--space-2);
    }

    .hero__links a {
      padding-inline: var(--space-3);
    }

    .section-heading {
      align-items: start;
      flex-direction: column;
      gap: var(--space-2);
    }

    .section-heading h2 {
      font-size: var(--font-size-xl);
    }

  }
</style>
